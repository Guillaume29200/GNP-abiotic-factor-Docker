# --------------------------------------------------
# GNP Standard Docker Variables - Abiotic Factor
# --------------------------------------------------

# General
GNP_TZ=Europe/Paris
GNP_PUID=1000
GNP_PGID=1000

# Steam
GNP_STEAM_APP_ID=2857200
GNP_STEAM_USER=anonymous
GNP_STEAM_PASSWORD=
GNP_GAME_UPDATE=true
GNP_VALIDATE_FILES=false
GNP_STEAM_FORCE_PLATFORM=windows

# Server
GNP_SERVER_NAME=GNP Abiotic Factor Server
GNP_SERVER_PASSWORD=
GNP_ADMIN_PASSWORD=
GNP_MAX_PLAYERS=6
GNP_WORLD_SAVE_NAME=Cascade

# Network
GNP_GAME_PORT=7777
GNP_QUERY_PORT=27015
# LAN discovery uses UDP 14001 when LANOnly is enabled.

# Launch options
GNP_USE_PERF_THREADS=true
GNP_DISABLE_ASYNC_LOADING_THREAD=false
GNP_NO_ASYNC_LOADING_THREAD=false
GNP_LAN_ONLY=false
# Empty = crossplay enabled. Allowed values: PC, Playstation, Xbox
GNP_PLATFORM_LIMITED=
GNP_MULTIHOME=
GNP_USE_LOCAL_IPS=false
GNP_SANDBOX_INI_PATH=Config/WindowsServer/GNPSandboxSettings.ini
GNP_ADMIN_INI_PATH=
GNP_START_ARGS=

# Sandbox generation
GNP_WRITE_SANDBOX_CONFIG=true
GNP_SANDBOX_GAME_DIFFICULTY=1
GNP_SANDBOX_HARDCORE_MODE=False
GNP_SANDBOX_LOOT_RESPAWN_ENABLED=False
GNP_SANDBOX_POWER_SOCKETS_OFF_AT_NIGHT=True
GNP_SANDBOX_DAY_NIGHT_CYCLE_STATE=0
GNP_SANDBOX_DAY_NIGHT_CYCLE_SPEED_MULTIPLIER=1.0
GNP_SANDBOX_WEATHER_FREQUENCY=3
GNP_SANDBOX_SINK_REFILL_RATE=1.0
GNP_SANDBOX_FOOD_SPOIL_SPEED_MULTIPLIER=1.0
GNP_SANDBOX_REFRIGERATION_EFFECTIVENESS_MULTIPLIER=1.0
GNP_SANDBOX_STORAGE_BY_TAG=True
GNP_SANDBOX_STRUCTURAL_SUPPORT_LIMIT=5
GNP_SANDBOX_BRIDGE_SUPPORTS=2
GNP_SANDBOX_HOME_WORLDS=True
GNP_SANDBOX_INVISIBLE_RADIATION=False
GNP_SANDBOX_TAINTED_SINK_WATER=False
GNP_SANDBOX_RADIATION_DEALS_DAMAGE=False
GNP_SANDBOX_ENEMY_SPAWN_RATE=1.0
GNP_SANDBOX_ENEMY_HEALTH_MULTIPLIER=1.0
GNP_SANDBOX_ENEMY_PLAYER_DAMAGE_MULTIPLIER=1.0
GNP_SANDBOX_ENEMY_DEPLOYABLE_DAMAGE_MULTIPLIER=1.0
GNP_SANDBOX_DETECTION_SPEED_MULTIPLIER=1.0
GNP_SANDBOX_ENEMY_ACCURACY=2
GNP_SANDBOX_DAMAGE_TO_ALLIES_MULTIPLIER=0.5
GNP_SANDBOX_HUNGER_SPEED_MULTIPLIER=1.0
GNP_SANDBOX_THIRST_SPEED_MULTIPLIER=1.0
GNP_SANDBOX_FATIGUE_SPEED_MULTIPLIER=1.0
GNP_SANDBOX_CONTINENCE_SPEED_MULTIPLIER=1.0
GNP_SANDBOX_BONUS_PERK_POINTS=0
GNP_SANDBOX_PLAYER_XP_GAIN_MULTIPLIER=1.0
GNP_SANDBOX_ITEM_STACK_SIZE_MULTIPLIER=1.0
GNP_SANDBOX_ITEM_WEIGHT_MULTIPLIER=1.0
GNP_SANDBOX_ITEM_DURABILITY_MULTIPLIER=1.0
GNP_SANDBOX_DURABILITY_LOSS_ON_DEATH_MULTIPLIER=0.1
GNP_SANDBOX_SHOW_DEATH_MESSAGES=True
GNP_SANDBOX_ALLOW_RECIPE_SHARING=True
GNP_SANDBOX_ALLOW_PAGERS=True
GNP_SANDBOX_ALLOW_TRANSMOG=True
GNP_SANDBOX_DISABLE_RESEARCH_MINIGAME=False
GNP_SANDBOX_DEATH_PENALTIES=1
GNP_SANDBOX_FIRST_TIME_STARTING_WEAPON=0
GNP_SANDBOX_HOST_ACCESS_PLAYER_CORPSES=True
GNP_SANDBOX_ALLOW_CHARACTER_RESET=True
GNP_SANDBOX_BASE_INVENTORY_SIZE=12
GNP_SANDBOX_PLAYER_FURNITURE_DESTRUCTION=False
GNP_SANDBOX_ALLOW_IRON_MODE=True

# Wine / Xvfb
GNP_USE_WINE=true
GNP_WINEPREFIX=/opt/wine/abiotic-factor
GNP_WINEARCH=win64
GNP_DISPLAY=:99
GNP_XVFB_RESOLUTION=1024x768x16
GNP_WINEDEBUG=-all

# Execution
GNP_SERVER_EXE=AbioticFactorServer-Win64-Shipping.exe
